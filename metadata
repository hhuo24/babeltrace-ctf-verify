/* CTF 1.8 */

typealias integer { size = 8; align = 8; signed = false; base = 10; } := uint8_t;
typealias integer { size = 32; align = 8; signed = false; base = 10; } := uint32_t;
typealias integer { size = 64; align = 8; signed = false; base = 10; } := uint64_t;

trace {
    major = 1;
    minor = 8;
    byte_order = le;
    uuid = "2a6422d0-6cee-11e0-8c08-cb07d7b3a564";
    
    packet.header := struct {
    uint32_t magic; 
    uint8_t uuid[16];
    uint32_t stream_id;
};
    
};

clock {
    name = clock0;
    freq = 1000000000;
    precision = 1;
};

typealias integer {
    size = 64;
    align = 8;
    signed = false;
    map = clock.clock0.value;
} := timestamp_t;

stream {
    id = 0;

    packet.context := struct {
        uint64_t timestamp_begin;
        uint64_t timestamp_end;
        uint64_t content_size;
        uint64_t packet_size;
    };

    event.header := struct {
        uint64_t id;
        timestamp_t timestamp;
    };
};

event {
    name = silly_event;
    id = 0;
    stream_id = 0;
    fields := struct {
        uint64_t value;
    };
};
